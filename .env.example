# ──────────────────────────────────────────────────────
# ClaudeClaw Configuration
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── Telegram (required) ──────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram chat IDs
# Send /chatid to your bot to get yours
# Leave empty on first run to allow any chat (for setup)
ALLOWED_CHAT_IDS=

# ── Voice — Groq STT + TTS ──────────────────────────
# Free API key from https://console.groq.com
GROQ_API_KEY=

# TTS voice for /voice mode. Groq Orpheus voices:
#   autumn diana hannah austin daniel troy
TTS_VOICE=autumn

# ── WhatsApp Bridge ─────────────────────────────────
# Set to true to enable the WhatsApp bridge
# First run will show a QR code in the terminal to scan
WHATSAPP_ENABLED=false

# ── Scheduler ───────────────────────────────────────
# Set to false to disable the cron scheduler
SCHEDULER_ENABLED=true

# ── Video Analysis (optional) ───────────────────────
# Free API key from https://aistudio.google.com
GOOGLE_API_KEY=

# ── Logging ─────────────────────────────────────────
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ── Environment ─────────────────────────────────────
# Set to "production" to disable pretty logging
NODE_ENV=development

# ── Anthropic & Local Models ────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="http://localhost:11434"
ANTHROPIC_MODEL="kimi-k2.5:cloud"

# ── Gmail Skill ─────────────────────────────────────
# OAuth variables for Gmail skill support
GMAIL_CLIENT_ID="your_client_id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="your_client_secret"
GMAIL_REFRESH_TOKEN="1//your_refresh_token"
GMAIL_USER_EMAIL="your_email@gmail.com"
